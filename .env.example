# ╔══════════════════════════════════════════════════════════════╗
# ║  RYB v20.0 — Zero-Stress Environment Defaults              ║
# ║  Questo file è PUBBLICO e sincronizzabile su GitHub.        ║
# ║  Contiene solo valori di default per sviluppo locale.       ║
# ║  NON inserire mai secret reali qui.                         ║
# ╚══════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL via Docker)
# ═══════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ryb_development
DB_USER=ryb_dev
DB_PASSWORD=ryb_dev_secret_2026
DB_POOL_SIZE=10
DB_SSL=false

# ═══════════════════════════════════════════════════════════════
# REDIS (Cache + Job Queue via Docker)
# ═══════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════
# JWT (auto-generato se vuoto — sicuro e zero-stress)
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ═══════════════════════════════════════════════════════════════
# MINIO — Object Storage S3-compatible (Docker)
# ═══════════════════════════════════════════════════════════════
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ryb-uploads
MINIO_USE_SSL=false

# ═══════════════════════════════════════════════════════════════
# API KEYS — Opzionali, zero-cash se vuoti
# ═══════════════════════════════════════════════════════════════
# HUGGINGFACE_API_TOKEN=hf_...
# OPENAI_API_KEY=sk-...

# ═══════════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
MOBILE_URL=http://localhost:5174

# ═══════════════════════════════════════════════════════════════
# AI CORE
# ═══════════════════════════════════════════════════════════════
AI_PORT=3002
AI_STRATEGY=auto
OLLAMA_HOST=http://localhost:11434

# ═══════════════════════════════════════════════════════════════
# EMAIL (MailHog in dev, SMTP in prod)
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ryb.local

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=pretty

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:5173

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════
ENABLE_AI=true
ENABLE_EMAIL=true
ENABLE_UPLOADS=true
ENABLE_REALTIME=true
